rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only allow the backend (Admin SDK) to manage bookings.
    // However, if we ever switch back to client-side, we would restrict it here.
    match /bookings/{bookingId} {
      allow read: if false; // Only admin can read
      allow create: if true; // Anyone can submit a booking
      allow update, delete: if false; // No one can modify existing bookings via client
    }
  }
}
